{
  "name": "landscape-mcp",
  "version": "1.0.0",
  "description": "Local-stdio MCP server exposing the AI agent infrastructure landscape catalog (912 records × 68 columns + 528 typed edges). Read-only query interface over data/landscape.json + data/landscape.edges.json.",
  "type": "module",
  "bin": {
    "landscape-mcp": "./dist/server.js"
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node dist/test-tools.js",
    "prepare": "tsc",
    "prepack": "tsc && mkdir -p data && cp ../data/landscape.json ../data/landscape.edges.json data/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "memory",
    "landscape",
    "catalog"
  ],
  "license": "MIT",
  "author": "MrPeppersDev",
  "homepage": "https://github.com/MrPeppersDev/agent-infrastructure-landscape/tree/main/mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrPeppersDev/agent-infrastructure-landscape.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/MrPeppersDev/agent-infrastructure-landscape/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
