  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai-agents",
    "memory",
    "landscape",
    "catalog",
    "cli"
  ],
  "license": "MIT"
}
